@model IReadOnlyList<RoyalVIlla.DTO.VillaDTO>

@{
    ViewData["Title"] = "Manage Villas";
}

@if (TempData["success"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show villa-alert" role="alert">
        <span class="villa-alert__icon" aria-hidden="true">✓</span>
        <div><strong>Success!</strong> @successMessage</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["error"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show villa-alert" role="alert">
        <span class="villa-alert__icon" aria-hidden="true">!</span>
        <div><strong>Something went wrong.</strong> @errorMessage</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="villa-manage-header d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
    <div>
        <span class="section-eyebrow">Administration</span>
        <h1 class="display-6 fw-bold mb-1">Manage villas</h1>
        <p class="text-secondary mb-0">Review and maintain the villas in your collection.</p>
    </div>
    <a class="btn villa-hero__button align-self-start" asp-controller="Villa" asp-action="Create">
        Add villa
        <span aria-hidden="true">+</span>
    </a>
</section>

@if (Model.Count > 0)
{
    <div class="card border-0 shadow-sm villa-table-card">
        <div class="table-responsive">
            <table class="table align-middle villa-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">Villa</th>
                        <th scope="col">Rate</th>
                        <th scope="col">Occupancy</th>
                        <th scope="col">Size</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var villa in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(villa.ImageUrl))
                                    {
                                        <img class="villa-table__thumb" src="@villa.ImageUrl" alt="@villa.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <span class="villa-table__thumb villa-table__thumb--empty" aria-hidden="true">⌂</span>
                                    }
                                    <span class="fw-semibold">@villa.Name</span>
                                </div>
                            </td>
                            <td>@villa.Rate.ToString("C0") <span class="text-secondary small">/ night</span></td>
                            <td>@villa.Occupancy guests</td>
                            <td>@villa.Sqft.ToString("N0") sq ft</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="Villa" asp-action="Update" asp-route-id="@villa.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Villa" asp-action="Delete" asp-route-id="@villa.Id">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="villa-empty-state text-center border rounded-4 p-5">
        <div class="villa-empty-state__icon" aria-hidden="true">⌂</div>
        <h3 class="h4">No villas to manage yet</h3>
        <p class="text-secondary mb-0">Add your first villa to get started.</p>
    </div>
}
