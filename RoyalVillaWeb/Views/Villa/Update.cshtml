@model RoyalVIlla.DTO.VillaUpdateDTO

@{
    ViewData["Title"] = "Update Villa";
}

<section class="villa-manage-header d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
    <div>
        <span class="section-eyebrow">Administration</span>
        <h1 class="display-6 fw-bold mb-1">Update villa</h1>
        <p class="text-secondary mb-0">Edit the details below and save your changes.</p>
    </div>
    <a class="btn btn-outline-secondary align-self-start" asp-controller="Villa" asp-action="Index">
        <span aria-hidden="true">←</span> Back to list
    </a>
</section>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm villa-form-card">
            <div class="card-body p-4 p-md-5">
                <form asp-controller="Villa" asp-action="Update" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger villa-alert d-none-empty" role="alert"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label villa-form-label">Villa name</label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g. Garden Villa" autocomplete="off" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Details" class="form-label villa-form-label">Details</label>
                        <textarea asp-for="Details" class="form-control" rows="4" placeholder="Describe the villa, its surroundings and highlights..."></textarea>
                        <span asp-validation-for="Details" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12 col-sm-4">
                            <label asp-for="Rate" class="form-label villa-form-label">Rate / night</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Rate" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Rate" class="text-danger small"></span>
                        </div>
                        <div class="col-6 col-sm-4">
                            <label asp-for="Occupancy" class="form-label villa-form-label">Occupancy</label>
                            <div class="input-group">
                                <input asp-for="Occupancy" class="form-control" type="number" min="0" placeholder="0" />
                                <span class="input-group-text">guests</span>
                            </div>
                            <span asp-validation-for="Occupancy" class="text-danger small"></span>
                        </div>
                        <div class="col-6 col-sm-4">
                            <label asp-for="Sqft" class="form-label villa-form-label">Size</label>
                            <div class="input-group">
                                <input asp-for="Sqft" class="form-control" type="number" min="0" placeholder="0" />
                                <span class="input-group-text">sq ft</span>
                            </div>
                            <span asp-validation-for="Sqft" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImageUrl" class="form-label villa-form-label">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" type="url" placeholder="https://..."
                               oninput="document.getElementById('villaImagePreview').src = this.value" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 pt-2">
                        <button type="submit" class="btn villa-hero__button">
                            Save changes
                            <span aria-hidden="true">→</span>
                        </button>
                        <a class="btn btn-light" asp-controller="Villa" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm villa-form-card h-100">
            <div class="card-body p-4">
                <span class="villa-card__location">Live preview</span>
                <div class="villa-preview mt-2">
                    <img id="villaImagePreview" class="villa-preview__image"
                         src="@(string.IsNullOrWhiteSpace(Model?.ImageUrl) ? "https://placehold.co/600x400?text=Villa+Image" : Model!.ImageUrl)"
                         alt="Villa image preview"
                         onerror="this.src='https://placehold.co/600x400?text=Villa+Image'" />
                </div>
                <p class="text-secondary small mb-0 mt-3">
                    Update the image URL to preview it here. Changes are saved only after you select <strong>Save changes</strong>.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
