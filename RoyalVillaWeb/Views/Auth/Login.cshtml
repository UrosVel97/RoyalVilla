@model RoyalVIlla.DTO.LoginRequestDTO

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center g-4 py-4">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card border-0 shadow-sm villa-form-card">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <span class="section-eyebrow">Welcome back</span>
                    <h1 class="h3 fw-bold mb-1">Sign in to RoyalVilla</h1>
                    <p class="text-secondary mb-0">Enter your credentials to access your account.</p>
                </div>

                <form asp-controller="Auth" asp-action="Login" method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger villa-alert d-none-empty" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label villa-form-label">Email address</label>
                        <input asp-for="Email" class="form-control form-control-lg" type="email" placeholder="you@example.com" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label villa-form-label">Password</label>
                        <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="Enter your password" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 pt-2">
                        <button type="submit" class="btn villa-hero__button">
                            Sign in
                            <span aria-hidden="true">→</span>
                        </button>
                    </div>
                </form>

                <p class="text-center text-secondary small mb-0 mt-4">
                    Don't have an account?
                    <a asp-controller="Auth" asp-action="Register" class="fw-semibold text-decoration-none">Create one</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
